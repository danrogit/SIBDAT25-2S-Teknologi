<Window x:Class="TeknologiProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pakkesortering" Height="680" Width="1100" MinHeight="600" MinWidth="901"
        Background="#F5F7FA" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid Height="70" VerticalAlignment="Top" Background="{StaticResource MintGreenBrush}">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="200" />
				<ColumnDefinition Width="200" />
				<ColumnDefinition Width="150" />

			</Grid.ColumnDefinitions>
			<StackPanel Grid.Column="0">
				<TextBlock Text="📦 Pakkesortering" FontSize="28" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="24,0,0,0" />
			</StackPanel>

			<StackPanel Orientation="Horizontal" Grid.Column="1">
				<TextBlock VerticalAlignment="Center" Margin="0,0,20,0" FontSize="16">Active Postmen: </TextBlock>
				<TextBlock x:Name="PostmanCounter" HorizontalAlignment="Left" FontSize="16" TextWrapping="Wrap" VerticalAlignment="Center">X / X</TextBlock>
            </StackPanel>

			<StackPanel Orientation="Horizontal" Grid.Column="2">
				<TextBlock VerticalAlignment="Center" Margin="0,0,20,0" FontSize="16">Queue: </TextBlock>
				<TextBlock x:Name="QueueCounter" HorizontalAlignment="Left" TextWrapping="Wrap" FontSize="16" VerticalAlignment="Center">X</TextBlock>
            </StackPanel>

			<StackPanel Grid.Column="3" VerticalAlignment="Center">
				<Button Content="Start" HorizontalAlignment="Left" VerticalAlignment="Center" Background="Red" Height="40" Width="100" Click="StartUI"/>
			</StackPanel>
        </Grid>

        <Grid Margin="0,70,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" Margin="16,16,8,16" CornerRadius="10" BorderBrush="#DDE5E7" BorderThickness="1" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="20">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HeaderTextBlock}" Text="Opret Pakke" Margin="0,0,0,16" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Style="{StaticResource SubHeaderTextBlock}" Text="✉ Afsender" Margin="0,0,0,10" />

                                    <TextBlock Style="{StaticResource LabelTextBlock}" Text="Navn" />
                                    <TextBox x:Name="SenderNameTextBox" />

                                    <TextBlock Style="{StaticResource LabelTextBlock}" Text="By" />
                                    <TextBox x:Name="SenderCityTextBox" />

                                    <TextBlock Style="{StaticResource LabelTextBlock}" Text="Postnummer" />
                                    <TextBox x:Name="SenderPostalCodeTextBox" />

                                    <TextBlock Style="{StaticResource LabelTextBlock}" Text="Region" />
                                    <ComboBox x:Name="SenderRegionComboBox" ItemContainerStyle="{StaticResource ListBoxItemStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Style="{StaticResource SubHeaderTextBlock}" Text="🎁 Modtager" Margin="0,0,0,10" />

                                    <TextBlock Style="{StaticResource LabelTextBlock}" Text="Navn" />
                                    <TextBox x:Name="ReceiverNameTextBox" />

                                    <TextBlock Style="{StaticResource LabelTextBlock}" Text="Adresse" />
                                    <TextBox x:Name="ReceiverAddressTextBox" />

                                    <TextBlock Style="{StaticResource LabelTextBlock}" Text="By" />
                                    <TextBox x:Name="ReceiverCityTextBox" />

                                    <TextBlock Style="{StaticResource LabelTextBlock}" Text="Postnummer" />
                                    <TextBox x:Name="ReceiverPostalCodeTextBox" />

                                    <TextBlock Style="{StaticResource LabelTextBlock}" Text="Region" />
                                    <ComboBox x:Name="ReceiverRegionComboBox" ItemContainerStyle="{StaticResource ListBoxItemStyle}" />
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{StaticResource LightGrayBrush}" Margin="0,16,0,16" />

                            <TextBlock Style="{StaticResource LabelTextBlock}" Text="📏 Pakkestørrelse" Margin="0,0,0,8" />
                            <ComboBox x:Name="PackageSizeComboBox" ItemContainerStyle="{StaticResource ListBoxItemStyle}" Margin="0,0,0,20" />

                            <Button Content="✓ Sorter Pakke" Click="SortPackageButton_Click" 
                                    Height="40" FontSize="13" Padding="20,0" Margin="0,12,0,0" />

                            <TextBlock Margin="0,20,0,0" FontSize="11" Foreground="#95A0A8" Text="Formular nulstilles efter sortering" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1" Margin="8,16,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="10" BorderBrush="#DDE5E7" BorderThickness="1" Padding="16" Height="267" VerticalAlignment="Top" Grid.RowSpan="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource SubHeaderTextBlock}" Text="🚚 Lastbiler pr. Region" Margin="0,0,0,12" />
                        <ListBox Grid.Row="1" x:Name="TruckOverviewListBox" MaxHeight="180" 
                                 ItemContainerStyle="{StaticResource ListBoxItemStyle}" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="10" BorderBrush="#DDE5E7" BorderThickness="1" Padding="16" Margin="0,272,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource SubHeaderTextBlock}" Text="📋 Log" Margin="0,0,0,12" />
                        <ListBox Grid.Row="1" x:Name="LogListBox" 
                                 ItemContainerStyle="{StaticResource ListBoxItemStyle}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
